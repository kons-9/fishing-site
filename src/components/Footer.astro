---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-container">
    <div class="footer-content">
      <div class="footer-brand">
        <h3>🎣 Fishing Log</h3>
        <p>A personal record of fishing adventures and gear.</p>
      </div>
      <div class="footer-links">
        <a href="https://github.com/gotos/fishing-site" target="_blank" rel="noopener noreferrer">GitHub Repository</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} Fishing Log. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-dark);
    color: var(--color-text-muted);
    padding: var(--space-xl) 0 var(--space-md);
    margin-top: auto; /* Push to bottom */
  }

  .footer-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  .footer-brand h3 {
    color: var(--color-bg);
    margin-bottom: var(--space-xs);
  }

  .footer-brand p {
    font-size: 0.9rem;
    max-width: 300px;
  }

  .footer-links a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-primary-light);
  }

  .footer-bottom {
    text-align: center;
    padding-top: var(--space-lg);
    border-top: 1px solid hsl(210, 20%, 20%);
    font-size: 0.85rem;
  }

  @media (prefers-color-scheme: dark) {
    .site-footer {
      background-color: hsl(210, 25%, 5%);
    }
  }
</style>
